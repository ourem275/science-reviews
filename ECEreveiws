let index = 0;
const container = document.getElementById("reviews");

const dotsContainer = document.getElementById("dots");

function renderDots() {
  dotsContainer.innerHTML = reviews.map((_, i) => `
    <span class="dot ${i === index ? "active" : ""}" onclick="goToReview(${i})"></span>
  `).join("");
}

function goToReview(i) {
  index = i;
  render();
}
  
function render() {
  const r = reviews[index];

  container.innerHTML = `
    <div class="review-slide active">
      <div class="review-flex">

        <div class="review-text">
          <div class="name">${r.name}</div>
          <div class="stars">${r.stars}</div>
          <div class="text">${r.text}</div>
        </div>

        ${r.img ? `
          <div class="review-image">
            <img src="${r.img}" />
          </div>
        ` : ``}

      </div>
    </div>
  `;

  // 🔥 NEW: adjust container height smoothly
    requestAnimationFrame(() => {
    const box = document.querySelector(".review-box");
    const active = document.querySelector(".review-slide.active");

    if (box && active) {
      box.style.height = active.offsetHeight + 48 + "px";
    }
  });

  renderDots(); // 👈 add it here (ONLY once)
}
  
  setTimeout(() => {
  const box = document.querySelector(".review-box");
  const active = document.querySelector(".review-slide.active");

  if (box && active) {
    box.style.height = active.offsetHeight + 48 + "px";
  }
}, 50);
function nextReview() {
  index = (index + 1) % reviews.length;
  render();
}

function prevReview() {
  index = (index - 1 + reviews.length) % reviews.length;
  render();
}

render();

setInterval(() => {
  nextReview();
}, 5000);
</script>

</body>
</html>
